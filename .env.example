NODE_ENV=production
USE_MEMORY_DB=false
PORT=10000
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/DuelBet?retryWrites=true&w=majority
REDIS_URL=redis://your_redis_url:6379
JWT_SECRET=your_super_secret_key_min_32_chars_long
JWT_REFRESH_SECRET=another_super_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=https://your-frontend-domain.com
PAYNOW_ID=your_paynow_integration_id
PAYNOW_KEY=your_paynow_integration_key
PAYNOW_RESULT_URL=https://your-render-app.com/webhooks/paynow
PAYNOW_RETURN_URL=https://your-frontend-domain.com/payment/success
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=900000